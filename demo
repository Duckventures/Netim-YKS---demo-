// ─── POMODORO ────────────────────────────────────────────────────────────────
const POMO_CIRCUMFERENCE = 2 * Math.PI * 88; // 553

const pomoSettings = APP_STATE.pomoSettings;

let pomoMode      = 'study';   // study | short | long
let pomoRunning   = false;
let pomoInterval  = null;
let pomoSecondsLeft = pomoSettings.study * 60;
let pomoTotalSecs   = pomoSettings.study * 60;
let pomoCycleCount  = 0;       // how many study sessions done this loop (0–3)
let pomoSessionsDone = APP_STATE.pomoToday;
const LONG_BREAK_EVERY = 4;

const MODE_META = {
  study: { label: 'Çalışma Zamanı',  colorClass: 'study-color',  ringClass: '',               btnClass: 'mode-study' },
  short: { label: 'Kısa Mola ☕',    colorClass: 'short-color',  ringClass: 'mode-short-ring', btnClass: 'mode-short' },
  long:  { label: 'Uzun Mola 🌙',    colorClass: 'long-color',   ringClass: 'mode-long-ring',  btnClass: 'mode-long'  },
};

function savPomoSettings() {
  APP_STATE.pomoSettings = pomoSettings; persistState();
}

function pomoInit() {
  pomoSecondsLeft = pomoSettings[pomoMode] * 60;
  pomoTotalSecs   = pomoSettings[pomoMode] * 60;
  pomoRender();
  renderLoopDots();
  document.getElementById('pomoStreakCount').textContent = pomoSessionsDone;
  document.getElementById('adjStudy').textContent = pomoSettings.study;
  document.getElementById('adjShort').textContent = pomoSettings.short;
  document.getElementById('adjLong').textContent  = pomoSettings.long;
}

function pomoRender() {
  const m = String(Math.floor(pomoSecondsLeft / 60)).padStart(2,'0');
  const s = String(pomoSecondsLeft % 60).padStart(2,'0');
  document.getElementById('pomoDisplay').textContent = m + ':' + s;

  const meta = MODE_META[pomoMode];
  const display = document.getElementById('pomoDisplay');
  display.className = 'pomo-time ' + meta.colorClass;
  document.getElementById('pomoModeLabel').textContent = meta.label;

  const ring = document.getElementById('pomoRing');
  const progress = pomoTotalSecs > 0 ? pomoSecondsLeft / pomoTotalSecs : 1;
  ring.style.strokeDashoffset = POMO_CIRCUMFERENCE * (1 - progress);
  ring.className = 'pomo-ring-progress ' + meta.ringClass;

  document.getElementById('pomoPauseBtn').textContent = pomoRunning ? '⏸' : '▶';

  // mode buttons
  ['study','short','long'].forEach(m => {
    const btn = document.getElementById('mode' + m.charAt(0).toUpperCase() + m.slice(1));
    btn.classList.toggle('active', m === pomoMode);
  });
}

function renderLoopDots() {
  const container = document.getElementById('pomoLoops');
  let html = '';
  for (let i = 0; i < LONG_BREAK_EVERY; i++) {
    let cls = 'pomo-loop-dot';
    if (i < pomoCycleCount) cls += ' done';
    else if (i === pomoCycleCount && pomoMode === 'study') cls += ' active';
    html += '<div class="' + cls + '"></div>';
  }
  html += '<span class="pomo-loop-label">' + pomoCycleCount + ' / ' + LONG_BREAK_EVERY + '</span>';
  container.innerHTML = html;
}

function pomoToggle() {
  if (pomoRunning) {
    clearInterval(pomoInterval);
    pomoRunning = false;
  } else {
    pomoRunning = true;
    pomoInterval = setInterval(() => {
      pomoSecondsLeft--;
      pomoRender();
      if (pomoSecondsLeft <= 0) {
        clearInterval(pomoInterval);
        pomoRunning = false;
        pomoOnComplete();
      }
    }, 1000);
  }
  pomoRender();
}

function pomoOnComplete() {
  // Play a soft beep via Web Audio
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [0, 0.15, 0.3].forEach(delay => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.value = 660;
      gain.gain.setValueAtTime(0, ctx.currentTime + delay);
      gain.gain.linearRampToValueAtTime(0.3, ctx.currentTime + delay + 0.05);
      gain.gain.linearRampToValueAtTime(0, ctx.currentTime + delay + 0.35);
      osc.start(ctx.currentTime + delay);
      osc.stop(ctx.currentTime + delay + 0.4);
    });
  } catch(e) {}

  if (pomoMode === 'study') {
    pomoSessionsDone++;
    APP_STATE.pomoToday = pomoSessionsDone; persistState();
    document.getElementById('pomoStreakCount').textContent = pomoSessionsDone;
    pomoCycleCount++;
    if (pomoCycleCount >= LONG_BREAK_EVERY) {
      pomoCycleCount = 0;
      setMode('long');
    } else {
      setMode('short');
    }
  } else {
    setMode('study');
  }
  renderLoopDots();
  // auto-start next phase
  setTimeout(() => { pomoToggle(); }, 800);
}

function setMode(mode) {
  if (pomoRunning) { clearInterval(pomoInterval); pomoRunning = false; }
  pomoMode = mode;
  pomoSecondsLeft = pomoSettings[mode] * 60;
  pomoTotalSecs   = pomoSettings[mode] * 60;
  pomoRender();
  renderLoopDots();
}

function pomoSkip() {
  if (pomoRunning) { clearInterval(pomoInterval); pomoRunning = false; }
  pomoOnComplete();
}

function pomoPrev() {
  if (pomoRunning) { clearInterval(pomoInterval); pomoRunning = false; }
  pomoSecondsLeft = pomoSettings[pomoMode] * 60;
  pomoTotalSecs   = pomoSettings[pomoMode] * 60;
  pomoRender();
}

function adjustTime(type, delta) {
  const min = type === 'study' ? 5 : 1;
  const max = type === 'study' ? 90 : 30;
  pomoSettings[type] = Math.max(min, Math.min(max, pomoSettings[type] + delta));
  savPomoSettings();
  document.getElementById('adj' + type.charAt(0).toUpperCase() + type.slice(1)).textContent = pomoSettings[type];
  if (type === pomoMode && !pomoRunning) {
    pomoSecondsLeft = pomoSettings[type] * 60;
    pomoTotalSecs   = pomoSettings[type] * 60;
    pomoRender();
  }
}

