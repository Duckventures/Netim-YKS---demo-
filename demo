}

function getDeptObj() {
  if (!targetUni || !targetDept) return null;
  return UNI_DB[targetUni].departments.find(d => d.name === targetDept) || null;
}

function toggleLock(key) {
  if (lockedSubjects[key] !== undefined) {
    delete lockedSubjects[key];
  } else {
    const input = document.getElementById('tscore_' + key);
    lockedSubjects[key] = parseFloat(input.value) || 0;
  }
  renderTargetContent();
}

function onTargetScoreChange(key) {
  const val = parseFloat(document.getElementById('tscore_' + key).value) || 0;
  targetScores[key] = val;
  if (lockedSubjects[key] !== undefined) lockedSubjects[key] = val;
  computeAndRenderGap();
}

function renderTargetContent() {
  const dept = getDeptObj();
  const container = document.getElementById('targetContent');
  if (!dept) {
    container.innerHTML = '<div class="target-empty"><div style="font-size:32px;margin-bottom:8px">🎓</div>Hedef üniversiteni ve bölümünü seçerek başla.</div>';
    return;
  }

  const exam     = UNI_DB[targetUni].exam;
  const subjects = SUBJECTS[exam];

  // Calculate what YKS score the minScores (nets) would yield
  const minNets = {};
  subjects.forEach(s => { minNets[s.key] = dept.minScores[s.key] || 0; });
  const minYKS = calcScore(exam, minNets);
  const currentNets = {};
  subjects.forEach(s => { currentNets[s.key] = targetScores[s.key] || 0; });
  const currentYKS = calcScore(exam, currentNets);

  let html = `
    <div class="target-info-card">
      <div>
        <div class="target-uni-name">${targetUni}</div>
        <div class="target-dept-name">${dept.name} · ${exam}</div>
      </div>
      <div class="target-score-badge">
        <div class="target-score-num">${minYKS.toFixed(1)}</div>
        <div class="target-score-label">Min. YKS Puanı</div>
      </div>
    </div>`;

  html += '<div class="section-label" style="margin-top:4px">Net Karşılaştırması — Kilitle &amp; Analiz Et</div>';
  html += '<div style="font-size:12px;color:var(--muted);margin-bottom:12px">Değerler net olarak gösterilmektedir. Emin olduğun dersi kilitle.</div>';
  html += '<div class="target-subject-grid">';

  subjects.forEach(s => {
    const isLocked = lockedSubjects[s.key] !== undefined;
    const current  = targetScores[s.key] ?? 0;
    const required = dept.minScores[s.key] ?? 0;
    const gap      = current - required;
    let cardClass  = 'target-subject-card';
    if (isLocked)      cardClass += ' locked';
    else if (gap >= 0) cardClass += ' exceeds';
    else               cardClass += ' needs-work';

    html += `
      <div class="${cardClass}" id="tcard_${s.key}">
        <div class="target-subj-top">
          <span class="target-subj-name">${s.label}</span>
          <button class="lock-toggle ${isLocked ? 'on' : ''}" onclick="toggleLock('${s.key}')"></button>
        </div>
        <input class="target-subj-input" type="number" id="tscore_${s.key}"
          value="${current}" min="0" max="${s.max}" step="0.25"
          ${isLocked ? 'disabled' : ''}
          oninput="onTargetScoreChange('${s.key}')">
        <div style="font-size:9px;color:var(--muted);margin-top:1px">net</div>
        <div class="target-subj-required">
          Gerekli: <span class="req-num ${isLocked ? 'req-lock' : gap >= 0 ? 'req-ok' : 'req-warn'}">${required}</span> net
          ${isLocked ? ' 🔒' : gap >= 0 ? ' ✓' : ' (' + Math.abs(gap).toFixed(2) + ' net gerek)'}
        </div>
      </div>`;
  });

  html += '</div><div id="targetGapSection"></div>';
  container.innerHTML = html;
  computeAndRenderGap();
}

function computeAndRenderGap() {
  const dept = getDeptObj();
  if (!dept) return;
  const exam     = UNI_DB[targetUni].exam;
  const subjects = SUBJECTS[exam];

  // Current nets → YKS score
  const currentNets = {};
  subjects.forEach(s => { currentNets[s.key] = targetScores[s.key] || 0; });
  const currentYKS = calcScore(exam, currentNets);

  // Min required nets → YKS score
  const minNets = {};
  subjects.forEach(s => { minNets[s.key] = dept.minScores[s.key] || 0; });
  const minYKS = calcScore(exam, minNets);

  const yksGap   = currentYKS - minYKS;
  const pct      = Math.min(100, Math.round((currentYKS / minYKS) * 100));
  const barColor = yksGap >= 0 ? '#34d399' : pct > 70 ? '#fbbf24' : '#a855f7';
  const gapClass = yksGap > 0 ? 'gap-positive' : yksGap === 0 ? 'gap-zero' : 'gap-negative';
  const gapText  = yksGap > 0
    ? '+' + yksGap.toFixed(2) + ' puan fazla — Harika! 🎉'
    : yksGap === 0 ? '🎯 Tam İsabetli!'
    : Math.abs(yksGap).toFixed(2) + ' puan eksik';

  let html = `
    <div class="target-gap-card">
      <div class="target-gap-row">
        <span class="target-gap-label">Güncel YKS Puanı</span>
        <span class="target-gap-value" style="color:var(--text)">${currentYKS.toFixed(2)} / ${minYKS.toFixed(2)}</span>
      </div>
      <div class="target-progress-bar-wrap">
        <div class="target-progress-bar" style="width:${pct}%;background:${barColor};box-shadow:0 0 8px ${barColor}88"></div>
      </div>
      <div class="target-gap-row" style="margin-top:12px;margin-bottom:0">
        <span class="target-gap-label">Hedefe Mesafe</span>
        <span class="target-gap-value ${gapClass}">${gapText}</span>
      </div>
    </div>`;

  html += '<div class="section-label">Ders Bazlı Net Analizi</div>';
  html += '<div class="improvement-list">';

  subjects.forEach(s => {
    const current  = targetScores[s.key] || 0;
    const required = dept.minScores[s.key] || 0;
    const isLocked = lockedSubjects[s.key] !== undefined;
    const delta    = current - required;
    const barPct   = Math.min(100, Math.round((current / s.max) * 100));
    let deltaLabel, deltaClass, barColor2, rowClass = 'improvement-row';
    if (isLocked)        { deltaLabel = '🔒 Kilitli'; deltaClass = 'delta-lock'; barColor2 = '#a855f7'; }
    else if (delta >= 0) { deltaLabel = '+' + delta.toFixed(2) + ' net ✓'; deltaClass = 'delta-ok';   barColor2 = '#34d399'; rowClass += ' done'; }
    else                 { deltaLabel = delta.toFixed(2) + ' net'; deltaClass = 'delta-warn'; barColor2 = '#f87171'; }

    html += `
      <div class="${rowClass}">
        <span class="improvement-subj">${s.label}</span>
        <div class="improvement-bar-wrap">
          <div class="improvement-bar" style="width:${barPct}%;background:${barColor2};box-shadow:0 0 4px ${barColor2}88"></div>
        </div>
        <span style="font-size:10px;color:var(--muted);min-width:70px;text-align:center">${current.toFixed ? current.toFixed(2) : current} / ${required}</span>
        <span class="improvement-delta ${deltaClass}">${deltaLabel}</span>
      </div>`;
  });

  html += '</div>';
  const sec = document.getElementById('targetGapSection');
  if (sec) sec.innerHTML = html;
}

// ─── START ────────────────────────────────────────────────────────────────────
async function bootApp() {
  await loadState();
  Object.assign(pomoSettings, APP_STATE.pomoSettings);
  renderAll();
  renderCountdown();
  initTargetPage();
  pomoInit();
}

(function() {
  const splash = document.getElementById('splashScreen');
  if (!splash) return;
  setTimeout(() => {
    splash.classList.add('fade-out');
    setTimeout(() => splash.remove(), 850);
  }, 2500);
  splash.addEventListener('click', () => {
    splash.classList.add('fade-out');
    setTimeout(() => splash.remove(), 850);
  });
})();

bootApp();
</script>
</body>
</html>
