<script>
// ─── YKS NET & POINT CALCULATION ─────────────────────────────────────────────
// Net = correct - (wrong / 4)
// TYT base score = 100, each net contributes a subject-weighted coefficient
// AYT base score = 100, subject nets weighted by ÖSYM coefficients
//
// Official ÖSYM formula (simplified for practice tracking):
//   TYT Puan = 100 + Σ(net_i × coeff_i)
//   AYT Puan = 100 + Σ(net_i × coeff_i)
//
// Coefficients below are derived from ÖSYM's published score tables.
// TYT total questions: 120  AYT total questions: 80

const TYT_COEFFICIENTS = {
  turkce:    1.333,   // 40 questions, high weight
  sosyal:    1.000,   // 20 questions
  matematik: 1.333,   // 40 questions
  fen:       1.000,   // 20 questions
};

const AYT_COEFFICIENTS = {
  // Sayısal (MF) track weights — also used as general AYT
  mat:        3.000,
  fizik:      2.857,
  kimya:      2.857,
  biyoloji:   2.857,
  edebiyat:   3.000,
  tarih1:     3.000,
  cografya1:  3.000,
};

function calcNet(correct, wrong) {
  const net = correct - (wrong / 4);
  return Math.max(0, Math.round(net * 100) / 100); // floor at 0, 2dp
}

function calcTYTScore(nets) {
  let score = 100;
  for (const [key, coeff] of Object.entries(TYT_COEFFICIENTS)) {
    score += (nets[key] || 0) * coeff;
  }
  return Math.round(score * 100) / 100;
}

function calcAYTScore(nets) {
  let score = 100;
  for (const [key, coeff] of Object.entries(AYT_COEFFICIENTS)) {
    score += (nets[key] || 0) * coeff;
  }
  return Math.round(score * 100) / 100;
}

function calcScore(exam, nets) {
  return exam === 'TYT' ? calcTYTScore(nets) : calcAYTScore(nets);
}

// ─── PERSISTENT STATE ENGINE ──────────────────────────────────────────────────
// Uses IndexedDB — works on local files in Android Chrome, unlike localStorage.

const DB_NAME    = 'yks_takip_db';
const DB_VERSION = 1;
const STORE_NAME = 'state';
const STATE_KEY  = 'app_state';

let db = null;

const DEFAULT_STATE = {
  scores:      { TYT: [], AYT: [] },
  examDates:   { TYT: null, AYT: null },
  pomoSettings:{ study: 25, short: 5, long: 15 },
  pomoToday:   0,
  pomoDate:    new Date().toDateString()
};

// Deep clone helper
function cloneState(s) { return JSON.parse(JSON.stringify(s)); }

let APP_STATE = cloneState(DEFAULT_STATE);

function openDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(DB_NAME, DB_VERSION);
    req.onupgradeneeded = e => {
      e.target.result.createObjectStore(STORE_NAME);
    };
    req.onsuccess = e => resolve(e.target.result);
    req.onerror   = e => reject(e);
  });
}

async function loadState() {
  try {
    db = await openDB();
    const tx  = db.transaction(STORE_NAME, 'readonly');
    const store = tx.objectStore(STORE_NAME);
    const req = store.get(STATE_KEY);
    return new Promise(resolve => {
      req.onsuccess = () => {
        if (req.result) {
          // Merge with defaults so new keys are always present
          APP_STATE = Object.assign(cloneState(DEFAULT_STATE), req.result);
          // Reset pomo daily count if it's a new day
          const today = new Date().toDateString();
          if (APP_STATE.pomoDate !== today) {
            APP_STATE.pomoToday = 0;
            APP_STATE.pomoDate  = today;
          }
        }
        resolve();
      };
      req.onerror = () => resolve(); // fallback to defaults
    });
  } catch(e) {
    console.warn('IndexedDB unavailable, using in-memory state:', e);
  }
}

function persistState() {
  if (!db) return;
  try {
    const tx    = db.transaction(STORE_NAME, 'readwrite');
    const store = tx.objectStore(STORE_NAME);
    store.put(APP_STATE, STATE_KEY);
  } catch(e) {
    console.warn('Could not persist state:', e);
  }
}

// ─── DATA ────────────────────────────────────────────────────────────────────
const SUBJECTS = {
  TYT: [
    { key: 'turkce',    label: 'Türkçe',       max: 40 },
    { key: 'sosyal',    label: 'Sosyal Bilim',  max: 20 },
    { key: 'matematik', label: 'Matematik',     max: 40 },
    { key: 'fen',       label: 'Fen Bilimleri', max: 20 },
  ],
  AYT: [
    { key: 'mat',       label: 'Matematik',     max: 40 },
    { key: 'fizik',     label: 'Fizik',         max: 14 },
    { key: 'kimya',     label: 'Kimya',         max: 13 },
    { key: 'biyoloji',  label: 'Biyoloji',      max: 13 },
    { key: 'edebiyat',  label: 'Türk Ed.',      max: 24 },
    { key: 'tarih1',    label: 'Tarih-1',       max: 10 },
    { key: 'cografya1', label: 'Coğrafya-1',    max: 6  },
  ]
};

const COLORS_TYT = ['#a855f7','#c084fc','#d8b4fe','#7c3aed'];
const COLORS_AYT = ['#818cf8','#6366f1','#a5b4fc','#4f46e5','#c7d2fe','#e0e7ff','#6366f1'];

let currentExam = 'TYT';
let lineChart, barChart;

function getData() { return APP_STATE.scores; }
function saveData(d) { APP_STATE.scores = d; persistState(); }

// ─── INIT ─────────────────────────────────────────────────────────────────────
document.getElementById('todayDate').textContent = new Date().toLocaleDateString('tr-TR', {day:'numeric',month:'long',year:'numeric'});
document.getElementById('sessionDate').value = new Date().toISOString().split('T')[0];

function switchExam(exam) {
  currentExam = exam;
  document.querySelectorAll('.tab').forEach(t => {
    t.className = 'tab';
    if (t.textContent.startsWith(exam)) {
      t.classList.add(exam === 'TYT' ? 'active-tyt' : 'active-ayt');
    }
  });
  document.getElementById('saveBtn').className = 'save-btn save-btn-' + exam.toLowerCase();
  renderAll();
}

function renderAll() {
  renderInputs();
  renderStats();
  renderCharts();
  renderHistory();
  document.getElementById('entryLabel').textContent = currentExam + ' — Doğru / Yanlış Gir';
  document.getElementById('statsLabel').textContent = currentExam + ' — Genel Bakış';
  document.getElementById('historyTitle').textContent = currentExam + ' Oturumları';
}

// ─── INPUTS ──────────────────────────────────────────────────────────────────
function renderInputs() {
  const subjects = SUBJECTS[currentExam];
  const grid = document.getElementById('scoreGrid');
  grid.innerHTML = subjects.map(s => `
    <div class="score-card">
      <label>${s.label} <span style="color:var(--muted);font-weight:400">(/${s.max})</span></label>
      <div style="display:flex;gap:6px;margin-top:4px;">
        <div style="flex:1">
          <div style="font-size:9px;color:var(--success);font-weight:700;letter-spacing:.6px;margin-bottom:3px">DOĞRU</div>
          <input type="number" id="inp_${s.key}_d" min="0" max="${s.max}" placeholder="0"
            style="width:100%;border:none;outline:none;font-family:'DM Serif Display',serif;font-size:22px;color:var(--success);background:none;-moz-appearance:textfield;"
            oninput="onDYChange('${s.key}','${s.max}')">
        </div>
        <div style="width:1px;background:var(--border);margin:0 2px;"></div>
        <div style="flex:1">
          <div style="font-size:9px;color:var(--danger);font-weight:700;letter-spacing:.6px;margin-bottom:3px">YANLIŞ</div>
          <input type="number" id="inp_${s.key}_y" min="0" max="${s.max}" placeholder="0"
            style="width:100%;border:none;outline:none;font-family:'DM Serif Display',serif;font-size:22px;color:var(--danger);background:none;-moz-appearance:textfield;"
            oninput="onDYChange('${s.key}','${s.max}')">
        </div>
      </div>
      <div id="net_${s.key}" style="font-size:11px;color:var(--muted);margin-top:6px;min-height:16px"></div>
    </div>
  `).join('');
}

function onDYChange(key, max) {
  const d = parseFloat(document.getElementById('inp_' + key + '_d').value) || 0;
  const y = parseFloat(document.getElementById('inp_' + key + '_y').value) || 0;
  const net = calcNet(d, y);
  const netEl = document.getElementById('net_' + key);
  if (d > 0 || y > 0) {
    netEl.innerHTML = `Net: <span style="color:var(--purple-bright);font-weight:700">${net.toFixed(2)}</span>`;
  } else {
    netEl.innerHTML = '';
  }
}

// ─── SAVE ─────────────────────────────────────────────────────────────────────
function saveSession() {
  const subjects = SUBJECTS[currentExam];
  const nets = {};
  const corrects = {};
  const wrongs = {};
  let valid = true;

  for (const s of subjects) {
    const d = parseFloat(document.getElementById('inp_' + s.key + '_d').value);
    const y = parseFloat(document.getElementById('inp_' + s.key + '_y').value);
    if (isNaN(d) || d < 0 || d > s.max) { valid = false; break; }
    const yVal = isNaN(y) ? 0 : Math.min(y, s.max - d);
    if (d + yVal > s.max) { valid = false; break; }
    corrects[s.key] = d;
    wrongs[s.key] = yVal;
    nets[s.key] = calcNet(d, yVal);
  }

  if (!valid) {
    alert('Lütfen tüm alanlara geçerli değerler girin (Doğru + Yanlış ≤ Toplam soru sayısı).');
    return;
  }

  const yksScore = calcScore(currentExam, nets);
  const totalNet = Object.values(nets).reduce((a, b) => a + b, 0);

  const dateVal = document.getElementById('sessionDate').value;
  const data = getData();
  data[currentExam].push({ date: dateVal, nets, corrects, wrongs, totalNet: Math.round(totalNet * 100) / 100, yksScore });
  data[currentExam].sort((a, b) => a.date.localeCompare(b.date));
  saveData(data);

  // clear inputs
  subjects.forEach(s => {
    document.getElementById('inp_' + s.key + '_d').value = '';
    document.getElementById('inp_' + s.key + '_y').value = '';
    const netEl = document.getElementById('net_' + s.key);
    if (netEl) netEl.innerHTML = '';
  });

  const confirm = document.getElementById('saveConfirm');
  confirm.classList.add('visible');
  setTimeout(() => confirm.classList.remove('visible'), 2000);

  renderStats();
  renderCharts();
  renderHistory();
}

// ─── STATS ────────────────────────────────────────────────────────────────────
function renderStats() {
  const sessions = getData()[currentExam];
  const container = document.getElementById('statsRow');
  if (!sessions.length) {
    container.innerHTML = `<div class="empty-state" style="grid-column:1/-1;padding:20px;"><div style="font-size:13px;color:var(--muted)">Henüz kayıt yok. Yukarıdan puan girin!</div></div>`;
    return;
  }

  const last = sessions[sessions.length - 1];
  const prev = sessions.length > 1 ? sessions[sessions.length - 2] : null;
  const subjects = SUBJECTS[currentExam];
  const color = currentExam === 'TYT' ? 'var(--accent-tyt)' : 'var(--accent-ayt)';

  // Support old sessions that stored scores instead of nets
  const lastNets = last.nets || last.scores || {};
  const prevNets = prev ? (prev.nets || prev.scores || {}) : null;

  let html = '';
  subjects.forEach(s => {
    const curr = lastNets[s.key] || 0;
    const p = prevNets ? (prevNets[s.key] || 0) : null;
    const diff = p !== null ? curr - p : null;
    let trendHtml = '';
    if (diff !== null) {
      if (diff > 0) trendHtml = `<div class="stat-trend trend-up">↑ +${diff.toFixed(2)}</div>`;
      else if (diff < 0) trendHtml = `<div class="stat-trend trend-down">↓ ${diff.toFixed(2)}</div>`;
      else trendHtml = `<div class="stat-trend trend-flat">— Aynı</div>`;
    }
    html += `
      <div class="stat-card">
        <div class="stat-value" style="color:${color};font-size:22px">${curr.toFixed(2)}</div>
        <div class="stat-label">${s.label}</div>
        <div style="font-size:10px;color:var(--muted);margin-top:2px">net</div>
        ${trendHtml}
      </div>`;
  });

  // YKS Score card
  const yksScore = last.yksScore || last.total || 0;
  const prevYks  = prev ? (prev.yksScore || prev.total || 0) : null;
  let yksTrend = '';
  if (prevYks !== null) {
    const diff = yksScore - prevYks;
    if (diff > 0) yksTrend = `<div class="stat-trend trend-up">↑ +${diff.toFixed(2)}</div>`;
    else if (diff < 0) yksTrend = `<div class="stat-trend trend-down">↓ ${diff.toFixed(2)}</div>`;
    else yksTrend = `<div class="stat-trend trend-flat">— Aynı</div>`;
  }
  html += `
    <div class="stat-card" style="border-color:${color};border-width:2px;">
      <div class="stat-value" style="color:${color}">${yksScore.toFixed(2)}</div>
      <div class="stat-label">YKS Puanı</div>
      ${yksTrend}
    </div>`;

  container.innerHTML = html;
}

// ─── CHARTS ───────────────────────────────────────────────────────────────────
function renderCharts() {
  const sessions = getData()[currentExam];
  const subjects = SUBJECTS[currentExam];
  const colors = currentExam === 'TYT' ? COLORS_TYT : COLORS_AYT;
  const accent = currentExam === 'TYT' ? '#a855f7' : '#818cf8';

  if (lineChart) lineChart.destroy();
  if (barChart)  barChart.destroy();

  const lineCtx = document.getElementById('lineChart').getContext('2d');
  const barCtx  = document.getElementById('barChart').getContext('2d');

  // Give bar chart a minimum pixel width so bars don't squish on mobile
  const barSubjects = subjects.length;
  const barMinWidth = Math.max(320, barSubjects * 56);
  const barInner = document.querySelector('.chart-wrap-bar-inner');
  if (barInner) barInner.style.minWidth = barMinWidth + 'px';

  const labels = sessions.map(s => {
    const d = new Date(s.date);
    return d.toLocaleDateString('tr-TR', {day:'numeric', month:'short'});
  });

  // Line chart — YKS score over time
  lineChart = new Chart(lineCtx, {
    type: 'line',
    data: {
      labels: labels.length ? labels : ['—'],
      datasets: [{
        label: 'YKS Puanı',
        data: sessions.map(s => s.yksScore || s.total || 0),
        borderColor: accent,
        backgroundColor: accent + '18',
        borderWidth: 2.5,
        pointBackgroundColor: accent,
        pointRadius: 4,
        pointHoverRadius: 6,
        fill: true,
        tension: 0.35,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: {
        label: ctx => ' YKS: ' + ctx.parsed.y.toFixed(2)
      }}},
      scales: {
        x: { grid: { display: false }, ticks: { font: { family: 'DM Sans', size: 11 }, color: '#6b6a8a' } },
        y: { grid: { color: '#1e1a3a' }, ticks: { font: { family: 'DM Sans', size: 11 }, color: '#6b6a8a' }, beginAtZero: false }
      }
    }
  });

  // Bar chart — last session nets as % of max possible, so all subjects are comparable
  const lastSession = sessions.length ? sessions[sessions.length - 1] : null;
  const lastNets = lastSession ? (lastSession.nets || lastSession.scores || {}) : {};
  // % of max net (max net = all correct, 0 wrong = max questions)
  const lastNetPct = subjects.map(s => {
    const net = lastNets[s.key] || 0;
    return Math.round((net / s.max) * 100 * 10) / 10; // % to 1dp
  });

  barChart = new Chart(barCtx, {
    type: 'bar',
    data: {
      labels: subjects.map(s => s.label),
      datasets: [{
        label: 'Net %',
        data: lastNetPct,
        backgroundColor: colors.slice(0, subjects.length),
        borderRadius: 6,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: {
          label: ctx => {
            const s = subjects[ctx.dataIndex];
            const net = lastNets[s.key] || 0;
            return ` Net: ${net.toFixed(2)} / ${s.max}  (${ctx.parsed.y}%)`;
          }
        }}
      },
      scales: {
        x: { grid: { display: false }, ticks: { font: { family: 'DM Sans', size: 10 }, color: '#6b6a8a' } },
        y: {
          grid: { color: '#1e1a3a' },
          ticks: { font: { family: 'DM Sans', size: 11 }, color: '#6b6a8a', callback: v => v + '%' },
          beginAtZero: true,
          max: 100
        }
      }
    }
  });
}

// ─── HISTORY ──────────────────────────────────────────────────────────────────
function renderHistory() {
  const sessions = getData()[currentExam];
  const subjects = SUBJECTS[currentExam];
  const pill = currentExam === 'TYT' ? 'pill-tyt' : 'pill-ayt';
  const container = document.getElementById('historyBody');

  if (!sessions.length) {
    container.innerHTML = `<div class="empty-state"><div class="empty-icon">📋</div>Henüz oturum kaydedilmedi.</div>`;
    return;
  }

  const headers = subjects.map(s => `<th>${s.label}<br><span style="font-weight:400;color:var(--muted)">net</span></th>`).join('');
  const rows = [...sessions].reverse().map(sess => {
    const dateStr = new Date(sess.date).toLocaleDateString('tr-TR', {day:'numeric', month:'short', year:'numeric'});
    const nets = sess.nets || sess.scores || {};
    const corrects = sess.corrects || {};
    const wrongs   = sess.wrongs   || {};
    const cells = subjects.map(s => {
      const net = nets[s.key] || 0;
      const d   = corrects[s.key] !== undefined ? corrects[s.key] : '—';
      const y   = wrongs[s.key]   !== undefined ? wrongs[s.key]   : '—';
      return `<td>
        <div style="font-weight:700">${net.toFixed(2)}</div>
        <div style="font-size:10px;color:var(--muted)"><span style="color:var(--success)">${d}D</span> <span style="color:var(--danger)">${y}Y</span></div>
      </td>`;
    }).join('');
    const yks = sess.yksScore || sess.total || 0;
    return `<tr>
      <td>${dateStr}</td>
      ${cells}
      <td><span class="score-pill ${pill}">${typeof yks === 'number' ? yks.toFixed(2) : yks}</span></td>
    </tr>`;
  }).join('');

  container.innerHTML = `
    <table class="history-table">
      <thead><tr><th>Tarih</th>${headers}<th>YKS Puanı</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

function clearHistory() {
  if (!confirm('Bu sınavın tüm geçmişi silinecek. Emin misiniz?')) return;
  const data = getData();
  data[currentExam] = [];
  saveData(data);
  renderStats();
  renderCharts();
  renderHistory();
}

