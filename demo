let cdExam = 'TYT';
let cdInterval = null;

function getCdDates() {
  return APP_STATE.examDates;
}
function saveCdDates(d) { APP_STATE.examDates = d; persistState(); }

function switchCdExam(exam) {
  cdExam = exam;
  document.getElementById('cdTabTYT').className = 'exam-tab-cd' + (exam === 'TYT' ? ' active-tyt' : '');
  document.getElementById('cdTabAYT').className = 'exam-tab-cd' + (exam === 'AYT' ? ' active-ayt' : '');
  renderCountdown();
}

function showDateEdit() {
  const dates = getCdDates();
  const current = dates[cdExam] || '';
  document.getElementById('cdEditArea').innerHTML = `
    <div class="date-edit-row">
      <input type="date" id="cdDateInput" value="${current}">
      <button onclick="saveCdDate()">Kaydet</button>
      <button onclick="cancelCdEdit()" style="background:var(--bg);color:var(--muted);border:1px solid var(--border);">İptal</button>
    </div>`;
}

function cancelCdEdit() {
  document.getElementById('cdEditArea').innerHTML =
    '<button class="countdown-edit" onclick="showDateEdit()">📅 Sınav tarihini ayarla</button>';
}

function saveCdDate() {
  const val = document.getElementById('cdDateInput').value;
  if (!val) return;
  const dates = getCdDates();
  dates[cdExam] = val;
  saveCdDates(dates);
  cancelCdEdit();
  renderCountdown();
}

function renderCountdown() {
  if (cdInterval) clearInterval(cdInterval);
  updateCd();
  cdInterval = setInterval(updateCd, 30000);
}

function updateCd() {
  const dates = getCdDates();
  const dateStr = dates[cdExam];
  const headline = document.getElementById('cdHeadline');

  if (!dateStr) {
    headline.textContent = cdExam + ' sınav tarihi belirlenmedi';
    document.getElementById('cdDays').textContent = '—';
    document.getElementById('cdHours').textContent = '—';
    document.getElementById('cdMins').textContent = '—';
    document.getElementById('cdDayBlock').className = 'cd-block';
    return;
  }

  const examDate = new Date(dateStr + 'T09:00:00');
  const now = new Date();
  const diff = examDate - now;

  if (diff <= 0) {
    headline.textContent = cdExam + ' sınavı tamamlandı! 🎉';
    document.getElementById('cdDays').textContent = '0';
    document.getElementById('cdHours').textContent = '0';
    document.getElementById('cdMins').textContent = '0';
    return;
  }

  const days  = Math.floor(diff / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  const mins  = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

  const dateFormatted = new Date(dateStr).toLocaleDateString('tr-TR', {day:'numeric', month:'long', year:'numeric'});
  headline.textContent = cdExam + ' — ' + dateFormatted;

  document.getElementById('cdDays').textContent  = days;
  document.getElementById('cdHours').textContent = hours;
  document.getElementById('cdMins').textContent  = mins;

  const urgency = days <= 30 ? 'urgent' : days <= 90 ? 'soon' : 'safe';
  document.getElementById('cdDayBlock').className = 'cd-block ' + urgency;
}


